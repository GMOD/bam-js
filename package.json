{
  "name": "@gmod/bam",
  "version": "7.1.19",
  "description": "Parser for BAM and BAM index (bai) files",
  "license": "MIT",
  "repository": "GMOD/bam-js",
  "type": "module",
  "exports": {
    ".": {
      "import": "./esm/index.js",
      "require": "./dist/index.js"
    }
  },
  "author": {
    "name": "Colin Diesh",
    "email": "colin.diesh@gmail.com",
    "url": "https://github.com/cmdcolin"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "esm",
    "src"
  ],
  "scripts": {
    "format": "prettier --write .",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "lint": "eslint --report-unused-disable-directives --max-warnings 0",
    "clean": "rimraf dist esm",
    "prebuild": "pnpm clean && pnpm lint",
    "build:esm": "tsc --outDir esm",
    "build:es5": "tsc --module commonjs --moduleResolution bundler --outDir dist",
    "build": "pnpm build:esm && pnpm build:es5",
    "postbuild:es5": "echo '{\"type\": \"commonjs\"}' > dist/package.json",
    "preversion": "pnpm lint && npm test && pnpm build",
    "version": "standard-changelog && git add CHANGELOG.md",
    "postpublish": "git push origin master --follow-tags"
  },
  "keywords": [
    "bionode",
    "biojs",
    "bam",
    "genomics"
  ],
  "dependencies": {
    "@gmod/bgzf-filehandle": "^6.0.12",
    "@jbrowse/quick-lru": "^7.3.5",
    "crc": "^4.3.2",
    "generic-filehandle2": "^2.0.18"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.1",
    "eslint": "^9",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "standard-changelog": "^7.0.1",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.1"
  },
  "publishConfig": {
    "access": "public"
  }
}
